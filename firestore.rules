rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- neo-banking-dashboard (proyecto que comparte esta base) -----
    // cada usuario solo puede leer/escribir sus propios datos
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ----- tinder-clone -----

    // los perfiles son publicos para cualquier usuario autenticado (necesitas
    // verlos en el deck), pero cada quien solo edita el suyo.
    match /tinder_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // los swipes (likes/nopes) los escribe solo su dueño. la lectura la permito
    // tambien al destinatario del like, porque al swipear necesito comprobar si
    // esa persona ya me habia dado like para decidir si hay match.
    match /tinder_swipes/{userId}/likes/{targetId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == targetId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // un match solo lo ven y modifican sus dos participantes. para crearlo,
    // el usuario debe estar dentro del array users que se intenta escribir.
    match /tinder_matches/{matchId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.users;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.users;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.users;

      // mensajes del chat: visibles y escribibles por los participantes del match
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/tinder_matches/$(matchId)).data.users;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/tinder_matches/$(matchId)).data.users;
      }
    }
  }
}
