# las rutas de la app las maneja react-router en el cliente, asi que cualquier
# peticion que no sea un archivo real la mandamos al index.html. sin esto,
# recargar en /matches o /chat/xxx devuelve el 404 de apache.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # si el archivo o carpeta existe, se sirve tal cual
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # el resto va al index.html
  RewriteRule ^ index.html [L]
</IfModule>

# cache largo para los assets con hash, el index siempre fresco
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|svg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
